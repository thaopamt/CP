# API server
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=cp
DB_PASSWORD=cp
DB_NAME=cp

# Judge server (Piston)
PISTON_API_URL=http://localhost:2000/api/v2/execute
PISTON_CONTAINER=piston_api
PISTON_MAX_MEMORY_LIMIT_BYTES=512000000

# JWT
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=1d

# Web (Vite — VITE_ prefix is required to expose to client)
VITE_API_URL=/api
