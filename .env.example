# ── API server ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ── Postgres (external database) ─────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=dev-only-change-me-refresh
JWT_REFRESH_EXPIRES_IN=7d

# ── Cache ─────────────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_DEFAULT_TTL_MS=30000
CACHE_KEY_PREFIX=cp-system
CACHE_MEMORY_LRU_SIZE=5000
# Leave empty locally to use in-memory cache only. Docker/prod defaults to redis://redis:6379.
REDIS_URL=redis://redis:6379

# ── Judge server (Piston) ────────────────────────────────────────────
PISTON_API_URL=http://localhost:2000/api/v2/execute
PISTON_CONTAINER=piston_api
PISTON_RUN_TIMEOUT=30000
PISTON_COMPILE_TIMEOUT=30000
PISTON_RUN_MEMORY_LIMIT=512000000
PISTON_COMPILE_MEMORY_LIMIT=512000000
PISTON_OUTPUT_MAX_SIZE=10485760
SUBMISSION_JUDGE_CONCURRENCY=2

# ── Web (Vite — VITE_ prefix is required to expose to client) ────────
VITE_API_URL=/api
