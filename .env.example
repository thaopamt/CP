# ── API server ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ── Postgres (external database) ─────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=1d

# ── Judge server (Piston) ────────────────────────────────────────────
PISTON_API_URL=http://localhost:2000/api/v2/execute
PISTON_CONTAINER=piston_api
PISTON_RUN_TIMEOUT=30000
PISTON_COMPILE_TIMEOUT=30000
PISTON_RUN_MEMORY_LIMIT=512000000
PISTON_COMPILE_MEMORY_LIMIT=512000000

# ── Web (Vite — VITE_ prefix is required to expose to client) ────────
VITE_API_URL=/api
